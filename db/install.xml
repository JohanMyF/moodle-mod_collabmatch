<?xml version="1.0" encoding="UTF-8" ?>
<XMLDB PATH="mod/collabmatch/db" VERSION="2026031900" COMMENT="XMLDB file for mod_collabmatch"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="../../../lib/xmldb/xmldb.xsd"
>
    <TABLES>

        <TABLE NAME="collabmatch" COMMENT="Main table for Collaborative Match activity instances">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="course" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Course id"/>
                <FIELD NAME="name" TYPE="char" LENGTH="255" NOTNULL="true" COMMENT="Activity name"/>
                <FIELD NAME="intro" TYPE="text" NOTNULL="false" COMMENT="Activity introduction"/>
                <FIELD NAME="introformat" TYPE="int" LENGTH="4" NOTNULL="true" DEFAULT="0" COMMENT="Format of intro field"/>

                <FIELD NAME="prompttext" TYPE="text" NOTNULL="false" COMMENT="Prompt or instruction shown in the activity"/>
                <FIELD NAME="targetzones" TYPE="text" NOTNULL="false" COMMENT="Teacher-defined target zones, one per line"/>
                <FIELD NAME="matchpairs" TYPE="text" NOTNULL="false" COMMENT="Teacher-defined item to zone pairs, one per line"/>
                <FIELD NAME="grade" TYPE="number" LENGTH="10" DECIMALS="2" NOTNULL="true" DEFAULT="100.00" COMMENT="Maximum grade for the activity"/>
                <FIELD NAME="passingpercentage" TYPE="number" LENGTH="5" DECIMALS="2" NOTNULL="true" DEFAULT="50.00" COMMENT="Passing percentage required for success"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Time created"/>
                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Time modified"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="course_idx" UNIQUE="false" FIELDS="course"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="collabmatch_game" COMMENT="Stores shared game instances between two players">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>

                <FIELD NAME="collabmatchid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="Reference to activity instance"/>

                <FIELD NAME="playera" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="User ID of Player A"/>

                <FIELD NAME="playerb" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="User ID of Player B"/>

                <FIELD NAME="currentturn" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="User ID whose turn it is"/>

                <FIELD NAME="status" TYPE="char" LENGTH="20" NOTNULL="true" DEFAULT="waiting"
                    COMMENT="Game status: waiting, invited, active, finished"/>

                <FIELD NAME="lastmove" TYPE="text" NOTNULL="false"
                    COMMENT="Last move text shown to both players"/>

                <FIELD NAME="lastplayer" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="User ID of the learner who made the most recent move"/>

                <FIELD NAME="lastmovetime" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="Unix timestamp of most recent move"/>

                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="Time created"/>

                <FIELD NAME="timemodified" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0"
                    COMMENT="Time modified"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="collabmatch_idx" UNIQUE="false" FIELDS="collabmatchid"/>
                <INDEX NAME="playera_idx" UNIQUE="false" FIELDS="playera"/>
                <INDEX NAME="playerb_idx" UNIQUE="false" FIELDS="playerb"/>
            </INDEXES>
        </TABLE>

        <TABLE NAME="collabmatch_move" COMMENT="Stores individual moves made during a collaborative match game">
            <FIELDS>
                <FIELD NAME="id" TYPE="int" LENGTH="10" NOTNULL="true" SEQUENCE="true" COMMENT="Primary key"/>
                <FIELD NAME="gameid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Reference to collabmatch_game"/>
                <FIELD NAME="userid" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="User who made the move"/>
                <FIELD NAME="choice" TYPE="text" NOTNULL="false" COMMENT="Learner choice in readable form"/>
                <FIELD NAME="correct" TYPE="int" LENGTH="1" NOTNULL="true" DEFAULT="0" COMMENT="Whether the move was correct"/>
                <FIELD NAME="timecreated" TYPE="int" LENGTH="10" NOTNULL="true" DEFAULT="0" COMMENT="Time move was created"/>
            </FIELDS>

            <KEYS>
                <KEY NAME="primary" TYPE="primary" FIELDS="id"/>
            </KEYS>

            <INDEXES>
                <INDEX NAME="gameid_idx" UNIQUE="false" FIELDS="gameid"/>
                <INDEX NAME="userid_idx" UNIQUE="false" FIELDS="userid"/>
            </INDEXES>
        </TABLE>

    </TABLES>
</XMLDB>